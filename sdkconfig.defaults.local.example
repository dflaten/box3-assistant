# Copy this file to sdkconfig.defaults.local and fill in your local values.
# This file is ignored by git and can hold machine-specific secrets.

CONFIG_HUE_WIFI_SSID="your-ssid"
CONFIG_HUE_WIFI_PASSWORD="your-password"
CONFIG_HUE_BRIDGE_IP="192.168.68.60"
CONFIG_HUE_BRIDGE_API_KEY="your-hue-api-key"
CONFIG_HUE_BRIDGE_GROUP_ID="2"
